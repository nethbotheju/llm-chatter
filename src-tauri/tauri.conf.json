{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "llm Chatter",
  "version": "0.1.0",
  "identifier": "com.llmchatter.desktop",
  "build": {
    "frontendDist": "../out",
    "beforeDevCommand": "pnpm build:desktop",
    "beforeBuildCommand": "pnpm build:desktop"
  },
  "app": {
    "windows": [
      {
        "title": "llm Chatter",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/desktop-runtime"
    ],
    "resources": [
      "../desktop-runtime/dist"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
