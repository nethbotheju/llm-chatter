{
  "name": "llm-chatter",
  "version": "1.0.0",
  "description": "LLM Chat Application with multi-provider support",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "electron:dev": "node scripts/electron-dev.mjs",
    "electron:build": "node scripts/electron-build-renderer.mjs",
    "electron:build:dist": "pnpm electron:build && pnpm exec electron-builder",
    "electron:build:mac": "pnpm electron:build && pnpm exec electron-builder --mac && node scripts/notarize.mjs",
    "electron:build:win": "pnpm electron:build && pnpm exec electron-builder --win",
    "electron:build:linux": "pnpm electron:build && pnpm exec electron-builder --linux",
    "electron:build:all": "pnpm electron:build && pnpm exec electron-builder -mwl",
    "release": "pnpm electron:build:all && pnpm exec electron-builder --publish always"
  },
  "keywords": [],
  "author": "nethbotheju",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/mcp": "^2.0.3",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/react": "^3.0.118",
    "@mozilla/readability": "^0.6.0",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-slider": "^1.3.6",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "ai": "^6.0.116",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.9",
    "jsdom": "^29.1.1",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.1.7",
    "next": "^16.1.7",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.8",
    "prisma": "^6.19.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "turndown": "^7.2.4",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@eslint/eslintrc": "^3.3.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^28.0.3",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "electron": "^40.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "esbuild": "^0.25.11",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.7",
    "tsx": "^4.21.0",
    "vite": "^5.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "better-sqlite3",
      "prisma",
      "esbuild",
      "sharp",
      "unrs-resolver",
      "electron"
    ]
  }
}
